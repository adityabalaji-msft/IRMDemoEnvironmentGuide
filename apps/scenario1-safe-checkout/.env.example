# Application environment variables
# Copy to .env and populate with values from Bicep deployment outputs

# Application Insights (from: az deployment group show --query properties.outputs.appInsightsConnectionString)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://eastus-0.in.applicationinsights.azure.com/

# SQL Database (from: az deployment group show --query properties.outputs.sqlServerAliasFqdn)
# ✅ SAFE: This is set as an environment variable, not hard-coded in source
SQL_SERVER=zr-safe-sqlalias.database.windows.net
SQL_DATABASE=zr-safe-db
SQL_USER=sqladmin
SQL_PASSWORD=REPLACE_WITH_YOUR_PASSWORD

# Storage Account (from: az deployment group show --query properties.outputs.storageEndpoint)
# ✅ SAFE: This is set as an environment variable, not hard-coded in source
STORAGE_ACCOUNT_URL=https://zrsafestor.blob.core.windows.net/

# Scenario identifier
SCENARIO=scenario1-safe

# App port
PORT=3000
